# Server Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/xploitverse

# JWT Configuration
JWT_SECRET=xploitverse-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# CORS
CLIENT_URL=http://localhost:5173

# AWS Configuration (Phase 2+)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# AI APIs (Phase 2+)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# SMTP Email Configuration
# For Gmail: Host=smtp.gmail.com, Port=587, use App Password
# For SendGrid: Host=smtp.sendgrid.net, Port=587, Username=apikey, Password=<your-api-key>
# For Mailgun: Host=smtp.mailgun.org, Port=587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=XploitVerse
