# Server Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/xploitverse

# Redis (optional, used for caching/rate limiting in advanced flows)
REDIS_URL=redis://localhost:6379

# Razorpay Payment Gateway
# Test keys start with rzp_test_ ; live keys start with rzp_live_
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# JWT Configuration
JWT_SECRET=xploitverse-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# CORS
CLIENT_URL=http://localhost:5173

# AWS Configuration (Phase 2+)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# AI APIs (Phase 2+)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# SMTP Email Configuration
# For Gmail: Host=smtp.gmail.com, Port=587, use App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=XploitVerse
